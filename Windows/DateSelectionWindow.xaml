<Window x:Class="CN_GreenLumaGUI.Windows.DateSelectionWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        xmlns:local="clr-namespace:CN_GreenLumaGUI.Windows"
        mc:Ignorable="d"
        Title="{DynamicResource Settings_RollbackSteamVersionTitle}" 
        Height="250" Width="350"
        WindowStartupLocation="CenterOwner"
        FontFamily="/Fonts/#阿里巴巴普惠体"
        TextElement.Foreground="{DynamicResource MaterialDesignBody}"
        Background="{DynamicResource MaterialDesignPaper}">
    
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" 
                   Text="{DynamicResource Settings_RollbackSteamVersionTitle}" 
                   Style="{StaticResource MaterialDesignHeadline5TextBlock}" 
                   Margin="0,0,0,20" 
                   HorizontalAlignment="Center"/>
            
        <DatePicker Grid.Row="1"
                    SelectedDate="{Binding SelectedDate}" 
                    Margin="0,0,0,20" 
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Width="200"
                    Style="{StaticResource MaterialDesignOutlinedDatePicker}"/>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Command="{Binding CancelCmd}" 
                    Content="{DynamicResource Settings_RollbackSteamVersionCancel}" 
                    Style="{StaticResource MaterialDesignFlatButton}" 
                    Margin="0,0,10,0"/>
            <Button Command="{Binding ConfirmCmd}" 
                    Content="{DynamicResource Settings_RollbackSteamVersionConfirm}" 
                    Style="{StaticResource MaterialDesignRaisedButton}"/>
        </StackPanel>
    </Grid>
</Window>
